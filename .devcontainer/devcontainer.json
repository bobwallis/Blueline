{
	"name": "Blueline",
	"build": {
		"dockerfile": "Dockerfile",
		"context": "."
	},
	"mounts": [
		"source=blueline-postgres-data,target=/var/lib/postgresql,type=volume"
	],

	// Set *default* container specific settings.json values on container create.
	"customizations": {
		"vscode": {
			"settings": {
				"terminal.integrated.defaultProfile.linux": "zsh",
				"remote.autoForwardPorts": true,
				"remote.restoreForwardedPorts": true,
				"sqltools.connections": [{
					"name": "Container database",
					"driver": "PostgreSQL",
					"previewLimit": 50,
					"server": "localhost",
					"port": 5432,
					"database": "blueline",
					"username": "blueline",
					"password": "blueline"
				}],
				"php.validate.executablePath": "/usr/bin/php",
				"php.executablePath": "/usr/bin/php"
			},
			// IDs of extensions to install when the container is created.
			"extensions": [
				"github.vscode-pull-request-github",
				"mblode.twig-language-2",
				"redhat.vscode-yaml",
				"mikestead.dotenv",
				"mtxr.sqltools",
				"mtxr.sqltools-driver-pg",
				"bmewburn.vscode-intelephense-client"
			]
		}
	},
	"workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
	"portsAttributes": {
		"8000": {
			"label": "Blueline (Dev Server)",
			"onAutoForward": "openBrowserOnce",
			"protocol": "http"
		}
	},
	"otherPortsAttributes": {
		"onAutoForward": "notify"
	},
	// Connect as a non-root user. See https://aka.ms/vscode-remote/containers/non-root.
	"remoteUser": "vscode",
	"postCreateCommand": "chmod +x bin/provision && ./bin/provision",
	"postStartCommand": "if command -v pg_ctlcluster >/dev/null 2>&1; then pg_isready -h localhost -p 5432 >/dev/null 2>&1 || sudo pg_ctlcluster 17 main start; fi; bash ./bin/start-dev-frankenphp && bash ./bin/start-dev-image-server"
}
