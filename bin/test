#!/bin/bash

# Get script directory, and cd to repo root
SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ] ; do SOURCE="$(readlink "$SOURCE")"; done
d="$( cd -P "$( dirname "$SOURCE" )" && pwd )"
repo_root="$( cd "$d/.." && pwd )"
cd "$repo_root"

# Check test database exists and schema is accessible
if ! symfony console dbal:run-sql "SELECT 1" --env=test > /dev/null 2>&1; then
    echo -e "\n\033[1mSetting up test database\033[0m"
    echo -e "\n\033[33m⚠️  The following commands will be executed:\033[0m"
    echo -e "  1. symfony console doctrine:database:create --env=test --if-not-exists"
    echo -e "  2. symfony console doctrine:schema:create --env=test"
    echo ""
    read -p "Create test database and schema? (y/n) " -n 1 -r response
    echo
    if [[ ! $response =~ ^[Yy]$ ]]; then
        echo -e "\033[31mTest database setup cancelled. Cannot proceed with tests.\033[0m"
        exit 1
    fi
    echo -e "\n\033[1mCreating test database...\033[0m"
    if ! symfony console doctrine:database:create --env=test --if-not-exists; then
        echo -e "\033[31m✗ Failed to create test database\033[0m"
        echo "Tip: Ensure the database server is running and credentials are correct."
        exit 1
    fi
    echo -e "\n\033[1mCreating test database schema...\033[0m"
    if ! symfony console doctrine:schema:create --env=test; then
        echo -e "\033[31m✗ Failed to create test database schema\033[0m"
        echo "Tip: Try manually cleaning up and recreating:"
        echo "  symfony console doctrine:database:drop --env=test --force"
        echo "  symfony console doctrine:database:create --env=test"
        echo "  symfony console doctrine:schema:create --env=test"
        exit 1
    fi
    symfony console dbal:run-sql "CREATE EXTENSION IF NOT EXISTS fuzzystrmatch" --env=test > /dev/null
    echo -e "\n\033[32m✓ Test database ready\033[0m"
fi

# Check test database has method data
method_count=$(symfony console dbal:run-sql "SELECT COUNT(*) FROM methods" --env=test 2>/dev/null | sed -n 's/^ *\([0-9][0-9]*\) *$/\1/p')
if ! [[ "$method_count" =~ ^[0-9]+$ ]] || [ "$method_count" -eq 0 ]; then
    echo -e "\n\033[1mTest database has no method data\033[0m"
    echo -e "\n\033[33m⚠️  The following command will be executed:\033[0m"
    echo -e "  $repo_root/bin/fetchAndImportData --env=test"
    echo ""
    read -p "Import method data into test database now? (y/n) " -n 1 -r response
    echo
    if [[ ! $response =~ ^[Yy]$ ]]; then
        echo -e "\033[31mTest data import cancelled. Cannot proceed with tests.\033[0m"
        echo "Tip: Run this manually when ready: $repo_root/bin/fetchAndImportData --env=test"
        exit 1
    fi
    "$repo_root/bin/fetchAndImportData" --env=test
    method_count=$(symfony console dbal:run-sql "SELECT COUNT(*) FROM methods" --env=test 2>/dev/null | sed -n 's/^ *\([0-9][0-9]*\) *$/\1/p')
    if ! [[ "$method_count" =~ ^[0-9]+$ ]] || [ "$method_count" -eq 0 ]; then
        echo -e "\033[31m✗ Test database still appears empty after import\033[0m"
        exit 1
    fi
    echo -e "\n\033[32m✓ Test method data imported\033[0m"
fi

echo -e "\n\033[1mValidate database schema and mapping files\033[0m"
symfony console doctrine:schema:validate

echo -e "\n\033[1mLint Symfony container\033[0m"
symfony console lint:container

echo -e "\n\033[1mLint Twig templates\033[0m"
symfony console lint:twig src templates --excludes=vendor

echo -e "\n\033[1mLint PHP source (syntax + deprecations)\033[0m"
php_lint_failed=0
while IFS= read -r -d '' file; do
    output=$(php -d error_reporting=E_ALL -d display_errors=1 -l "$file" 2>&1)
    rc=$?

    if [ "$rc" -ne 0 ]; then
        echo "$output"
        php_lint_failed=1
        break
    fi

    if echo "$output" | grep -qi "deprecated"; then
        echo "$output"
        php_lint_failed=1
        break
    fi
done < <(find src -type f -name '*.php' -print0)

if [ "$php_lint_failed" -ne 0 ]; then
    echo -e "\033[31m✗ PHP lint failed in src (syntax error or deprecation detected)\033[0m"
    exit 1
fi

echo -e "\033[32m✓ PHP source lint passed\033[0m"

echo -e "\n\033[1mCheck PHP code style (PSR-12)\033[0m"
if ! "$repo_root/vendor/bin/php-cs-fixer" fix --config="$repo_root/.php-cs-fixer.dist.php" --dry-run --diff --verbose; then
    echo -e "\033[33m⚠ PHP style check found PSR-12 violations in src/tests\033[0m"
    echo "  Run: symfony composer fix:php-style to fix"
else
    echo -e "\033[32m✓ PHP style check passed\033[0m"
fi

echo -e "\n\033[1mLint frontend assets (JS, CSS, SVG)\033[0m"
if ! npm run lint; then
    echo -e "\033[31m✗ Frontend asset lint failed\033[0m"
    exit 1
fi
echo -e "\033[32m✓ Frontend asset lint passed\033[0m"

echo -e "\n\033[1mCompile production assets\033[0m"
"$repo_root/bin/buildFrontendAssets" --env=prod > /dev/null
if [ ! -f public/assets/manifest.json ]; then
    echo -e "\033[31m✗ Asset compilation failed - manifest.json not generated\033[0m"
    exit 1
fi
if [ ! -f public/favicon.ico ] || [ ! -f public/favicon.svg ] || [ ! -f public/service_worker.js ]; then
    echo -e "\033[31m✗ Root public assets missing (favicon or service worker)\033[0m"
    exit 1
fi
echo -e "\033[32m✓ Production assets compiled successfully\033[0m"
"$repo_root/bin/buildFrontendAssets" > /dev/null # Re-run without setting --env so that in dev the compiled assets are deleted again

echo -e "\n\033[1mRunning PHPUnit tests\033[0m"
APP_ENV=test "$repo_root/bin/phpunit"
