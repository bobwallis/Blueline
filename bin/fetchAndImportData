#!/bin/bash

# Get script directory, and cd to the parent folder
SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ] ; do SOURCE="$(readlink "$SOURCE")"; done
d="$( cd -P "$( dirname "$SOURCE" )" && pwd )"
cd "$d/../"

APP_ENVIRONMENT="${APP_ENV:-dev}"
SKIP_PULL=0
for arg in "$@"; do
	case "$arg" in
		--env=*)
			APP_ENVIRONMENT="${arg#*=}"
			;;
		--nopull)
			SKIP_PULL=1
			;;
		dev|test|prod)
			APP_ENVIRONMENT="$arg"
			;;
	esac
done

if [ "$SKIP_PULL" -eq 0 ]; then
	# Download external data
	echo -e "\n\033[1mDownloading external data\033[0m"
	"./src/Resources/data/fetch"
	echo ""
fi

# Import updated method data
symfony console blueline:importMethods --no-debug --env="$APP_ENVIRONMENT"
symfony console blueline:importMethodExtras --no-debug --env="$APP_ENVIRONMENT"
symfony console blueline:importCollections --no-debug --env="$APP_ENVIRONMENT"
symfony console blueline:calculateMethodSimilarities --no-debug --env="$APP_ENVIRONMENT"
symfony console dbal:run-sql "VACUUM" --env="$APP_ENVIRONMENT"
echo ""

if [ "$APP_ENVIRONMENT" = "dev" ]; then
	DATABASE_UPDATE_FILE=".env.local"
else
	DATABASE_UPDATE_FILE=".env.${APP_ENVIRONMENT}.local"
fi

touch "$DATABASE_UPDATE_FILE"
if grep -q '^DATABASE_UPDATE=' "$DATABASE_UPDATE_FILE"; then
	sed -i -e"s/^DATABASE_UPDATE=.*/DATABASE_UPDATE=`date "+%s"`/" "$DATABASE_UPDATE_FILE"
else
	echo "DATABASE_UPDATE=`date "+%s"`" >> "$DATABASE_UPDATE_FILE"
fi
