#!/bin/bash
set -euo pipefail

# ##############################################################################
# PREAMBLE — resolve repo root, parse args, detect environment
# ##############################################################################

SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do SOURCE="$(readlink "$SOURCE")"; done
d="$( cd -P "$( dirname "$SOURCE" )" && pwd )"
REPO_ROOT="$( cd "$d/.." && pwd )"
cd "$REPO_ROOT"

ENV_LOCAL_FILE="$REPO_ROOT/.env.local"

usage() {
cat << EOF

Usage: $0 [options]
This script sets up or re-runs setup for Blueline. It is idempotent and safe to run multiple times.

Options:
 --yes, -y      Non-interactive: answer yes to all prompts (also set automatically when running in Docker)
 --env=dev|prod  Set APP_ENV directly
 --nodatabase    Skip local PostgreSQL install and configuration
 --nocloudflared Skip cloudflared install and tunnel setup (prod only)
 --noserver      Skip FrankenPHP install and service setup (prod only)
 --help          Shows this message
EOF
}

NONINTERACTIVE=false
ENV_ARG=""
NODATABASE_ARG=false
NODATABASE_ARG_SET=false
NOCLOUDFLARED_ARG=false
NOCLOUDFLARED_ARG_SET=false
NOSERVER_ARG=false
NOSERVER_ARG_SET=false
AFTER_DOUBLE_DASH=false
for arg in "$@"; do
	if [ "$AFTER_DOUBLE_DASH" = true ]; then
		printf >&2 '%s: unexpected positional argument: %s\n' "${0##*/}" "$arg"
		usage
		exit 1
	fi
	case "$arg" in
		--)
			AFTER_DOUBLE_DASH=true
			;;
		--yes|-y)
			NONINTERACTIVE=true
			;;
		--env=dev|--env=prod)
			ENV_ARG="${arg#--env=}"
			;;
		--env=*)
			printf >&2 '%s: invalid value for --env (must be dev or prod): %s\n' "${0##*/}" "${arg#--env=}"
			usage
			exit 1
			;;
		--nodatabase)
			NODATABASE_ARG=true
			NODATABASE_ARG_SET=true
			;;
		--nocloudflared)
			NOCLOUDFLARED_ARG=true
			NOCLOUDFLARED_ARG_SET=true
			;;
		--noserver)
			NOSERVER_ARG=true
			NOSERVER_ARG_SET=true
			;;
		--help)
			usage
			exit 0
			;;
		--*)
			printf >&2 '%s: unknown option: %s\n' "${0##*/}" "$arg"
			usage
			exit 1
			;;
		-*)
			printf >&2 '%s: unknown option: %s\n' "${0##*/}" "$arg"
			usage
			exit 1
			;;
		*)
			printf >&2 '%s: unexpected positional argument: %s\n' "${0##*/}" "$arg"
			usage
			exit 1
			;;
	esac
done

# Detect Docker, and assume set-up is happening in a .devcontainer in that case, so force non-interactive
IS_DOCKER=false
if [ -f /.dockerenv ]; then
	IS_DOCKER=true
	NONINTERACTIVE=true
fi

if [ -n "$ENV_ARG" ]; then
	APP_ENV="$ENV_ARG"
else
	APP_ENV=""
	if [ -f "$ENV_LOCAL_FILE" ]; then
		APP_ENV="$(sed -nE 's/^[[:space:]]*APP_ENV[[:space:]]*=[[:space:]]*//p' "$ENV_LOCAL_FILE" | tail -n 1 | sed -E 's/[[:space:]]*$//' | sed -E 's/^"(.*)"$/\1/; s/^\x27(.*)\x27$/\1/')"
	fi
	if [ -z "$APP_ENV" ]; then
		if [ "$IS_DOCKER" = true ] || [ "$NONINTERACTIVE" = true ]; then
			APP_ENV="dev"
		else
			while true; do
				read -r -p "Choose APP_ENV: 'dev' or 'prod'? [prod]: " _app_env_choice
				_app_env_choice="${_app_env_choice:-prod}"
				_app_env_choice="${_app_env_choice,,}"
				case "$_app_env_choice" in
					dev)
						APP_ENV="dev"
						break
						;;
					prod)
						APP_ENV="prod"
						break
						;;
					*)
						echo "Please enter 'dev' or 'prod'."
						;;
				esac
			done
		fi
	fi
fi

# ask_yes_no "Prompt" [noninteractive_default_yes]
# Returns 0 for yes, 1 for no. In non-interactive mode defaults to "no" unless second arg is "yes".
ask_yes_no() {
	local prompt="$1"
	local noninteractive_default_yes="${2:-no}"
	if [ "$NONINTERACTIVE" = true ]; then
		if [ "$noninteractive_default_yes" = "yes" ]; then
			return 0
		fi
		return 1
	fi
	read -r -p "$prompt" _answer
	if [[ "$_answer" =~ ^[Yy]$ ]]; then
		return 0
	fi
	return 1
}

decision_for_display() {
	local value="$1"
	local is_set="$2"
	if [ "$is_set" = true ]; then
		echo "$value"
	else
		echo "to check"
	fi
}

# Resolve a skip decision only when needed by a section.
# Usage: resolve_skip_decision <value_var> <set_var> <prompt>
resolve_skip_decision() {
	local value_var_name="$1"
	local set_var_name="$2"
	local prompt="$3"
	local -n value_var_ref="$value_var_name"
	local -n set_var_ref="$set_var_name"

	if [ "$set_var_ref" = false ]; then
		if ask_yes_no "$prompt [y/N] "; then
			value_var_ref=true
		else
			value_var_ref=false
		fi
		set_var_ref=true
	fi
}

echo -e "\n\033[1mBlueline setup\033[0m"
echo "  REPO_ROOT:      $REPO_ROOT"
echo "  IS_DOCKER:      $IS_DOCKER"
echo "  NONINTERACTIVE: $NONINTERACTIVE"
echo "  APP_ENV:        $APP_ENV"
echo "  NODATABASE_ARG: $(decision_for_display \"$NODATABASE_ARG\" \"$NODATABASE_ARG_SET\")"
echo "  NOSERVER_ARG:   $(decision_for_display \"$NOSERVER_ARG\" \"$NOSERVER_ARG_SET\")"
echo "  NOCLOUDFLARED_ARG: $(decision_for_display \"$NOCLOUDFLARED_ARG\" \"$NOCLOUDFLARED_ARG_SET\")"

# ##############################################################################
# SECTION 1: OS check (VM only — skipped inside Docker)
# ##############################################################################

if [ "$IS_DOCKER" = false ]; then
	echo -e "\n\033[1mChecking OS\033[0m"

	if [ ! -f /etc/os-release ]; then
		echo "ERROR: /etc/os-release not found. Cannot determine OS." >&2
		exit 1
	fi

	# shellcheck source=/dev/null
	. /etc/os-release

	if [ "${ID:-}" != "debian" ]; then
		echo "ERROR: This script requires Debian. Detected: ${ID:-unknown} ${VERSION_CODENAME:-}" >&2
		exit 1
	fi

	VERSION_NUM="${VERSION_ID%%.*}"
	if [ "$VERSION_NUM" -lt 13 ]; then
		echo "ERROR: Debian 13 (Trixie) or later is required. Detected: Debian $VERSION_ID (${VERSION_CODENAME:-})" >&2
		exit 1
	fi

	if [ "$VERSION_NUM" -gt 13 ]; then
		echo
		echo "  WARNING: Detected Debian $VERSION_ID (${VERSION_CODENAME:-}), which is newer than Trixie (13). This script has not been tested on this version."
		if ! ask_yes_no "  Continue? [y/N] " yes; then
			echo "Aborted."
			exit 1
		fi
	fi

	echo "  OS: Debian $VERSION_ID (${VERSION_CODENAME:-}) — OK"
fi


# ##############################################################################
# SECTION 2: System package installation
# ##############################################################################

echo -e "\n\033[1mInstalling system packages\033[0m"

sudo apt-get update -qq && sudo apt-get upgrade -q -y --no-install-recommends

# Core tools
sudo apt-get install -q -y --no-install-recommends \
	apt-utils jq locales sudo zip wget tree lsof procps dirmngr psmisc net-tools unzip curl nano less gpg lsb-release zsh brotli zstd zopfli tzdata

# Symfony CLI — add Cloudsmith apt source if not already present
if [ ! -f /etc/apt/sources.list.d/symfony-stable.list ]; then
	echo "  Adding Symfony CLI apt source..."
	curl -1sLf 'https://dl.cloudsmith.io/public/symfony/stable/setup.deb.sh' | sudo -E bash -
fi
sudo apt-get install -q -y symfony-cli

# Postgres client, plus PHP 8.4 and extensions (Debian Trixie default — no extra apt source needed)
sudo apt-get install -y -q --no-install-recommends \
	postgresql-client-17 \
	composer php8.4-cli php8.4-opcache php8.4-pgsql php8.4-intl php8.4-mbstring php8.4-xml php8.4-zip php8.4-curl

if [ "$APP_ENV" = "dev" ]; then
	# Install some CLI tools used by VS Code
	sudo apt-get install -y -q --no-install-recommends \
		ripgrep silversearcher-ag shellcheck
fi

# Clean up apt caches
sudo apt-get autoremove -y -q
sudo apt-get clean
sudo rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/* || true

echo "  System packages: done."


# ##############################################################################
# SECTION 2.5: Locale and timezone
# ##############################################################################

echo -e "\n\033[1mConfiguring locale and timezone\033[0m"

if ! grep -q '^en_GB.UTF-8 UTF-8$' /etc/locale.gen; then
	echo "en_GB.UTF-8 UTF-8" | sudo tee -a /etc/locale.gen > /dev/null
fi
sudo locale-gen en_GB.UTF-8 > /dev/null
sudo update-locale LANG=en_GB.UTF-8 LC_ALL=en_GB.UTF-8
export LANG=en_GB.UTF-8
export LC_ALL=en_GB.UTF-8
echo "  Locale set to en_GB.UTF-8."

if [ -f /usr/share/zoneinfo/Europe/London ]; then
	echo "Europe/London" | sudo tee /etc/timezone > /dev/null
	sudo ln -snf /usr/share/zoneinfo/Europe/London /etc/localtime
	if [ "$IS_DOCKER" = false ] && command -v timedatectl > /dev/null 2>&1; then
		sudo timedatectl set-timezone Europe/London || true
	fi
	echo "  Timezone set to Europe/London."
else
	echo "WARNING: /usr/share/zoneinfo/Europe/London not found; timezone unchanged." >&2
fi


# ##############################################################################
# SECTION 3: PostgreSQL setup
# ##############################################################################

echo -e "\n\033[1mConfiguring PostgreSQL\033[0m"

resolve_skip_decision NODATABASE_ARG NODATABASE_ARG_SET "Skip PostgreSQL install and configuration?"
if [ "$NODATABASE_ARG" = true ]; then
	echo "  Skipping PostgreSQL setup (--nodatabase)."
	echo "  Reminder: configure a reachable PostgreSQL server and credentials yourself."
else
	# Install PostgreSQL 17 (Debian Trixie default — no extra apt source needed)
	sudo apt-get install -y -q --no-install-recommends postgresql-17

	DB_PASS=""
	if [ "$IS_DOCKER" = false ]; then
		sudo systemctl enable --now postgresql
	else
		# Containers generally do not run systemd as PID 1; start cluster directly.
		if ! sudo pg_ctlcluster 17 main start; then
			# pg_ctlcluster returns non-zero when the cluster is already running.
			if sudo pg_ctlcluster 17 main status > /dev/null 2>&1; then
				echo "  PostgreSQL cluster already running."
			else
				echo "ERROR: Failed to start PostgreSQL cluster 17/main." >&2
				exit 1
			fi
		fi
		DB_PASS="blueline"
	fi

	# Create role if it doesn't already exist
	_role_exists="$(sudo -u postgres psql -tAc "SELECT 1 FROM pg_roles WHERE rolname='blueline'" 2>/dev/null || true)"
	if [ "$_role_exists" != "1" ]; then
		if [ -z "$DB_PASS" ]; then
			DB_PASS="$(openssl rand -hex 16)"
		fi
		sudo -u postgres psql -c "CREATE ROLE blueline LOGIN PASSWORD '${DB_PASS}';"
		echo "  Created PostgreSQL role 'blueline'."
	else
		if [ "$IS_DOCKER" = true ]; then
			sudo -u postgres psql -c "ALTER ROLE blueline WITH PASSWORD '${DB_PASS}';"
			echo "  PostgreSQL role 'blueline' already exists — password reset to default Docker value."
		else
			echo "  PostgreSQL role 'blueline' already exists — skipping creation."
		fi
	fi

	# Create database if it doesn't already exist
	_db_exists="$(sudo -u postgres psql -tAc "SELECT 1 FROM pg_database WHERE datname='blueline'" 2>/dev/null || true)"
	if [ "$_db_exists" != "1" ]; then
		sudo -u postgres psql -c "CREATE DATABASE blueline OWNER blueline;"
		echo "  Created PostgreSQL database 'blueline'."
	else
		echo "  PostgreSQL database 'blueline' already exists — skipping creation."
	fi

	# Configure the database with some sensible options for expected size / workload
	# Assume small DB, expected to fit fully in memory; mostly read operations with infrequent, large/batched writes; running on a machine with 1-2 GB RAM and fast storage, e.g. SSD or NVMe.
	_pg_conf_dir="/etc/postgresql/17/main/conf.d"
	_pg_tuning_conf="$_pg_conf_dir/blueline.conf"
	_desired_pg_tuning="$(cat << 'PGCONF'
# Blueline tuning — small (~70 MB) DB expected to fit fully in shared_buffers
shared_buffers = 256MB # Enough to hold the whole DB in memory, but not so much that it would cause swapping on a machine with 1-2 GB RAM (e.g. small VM)
effective_cache_size = 512MB # Assume enough RAM to cache the whole DB and more, to encourage index use
work_mem = 256MB
maintenance_work_mem = 256MB
checkpoint_completion_target = 0.9 # Likely won't have enough WAL to fully utilise this, but good to have it set for safety
random_page_cost = 1.1 # Assume fast storage to encourage index use
effective_io_concurrency = 200 # Assume fast storage (e.g. NVMe) to encourage more aggressive use of indexes
synchronous_commit = off # Buffer writes, fine as updates will be rare and data loss on crash is acceptable
checkpoint_timeout = 5min # Only flush to disk every 5 mins, which should batch everything
max_wal_size = 1GB # Will never reach this in 5min with the expected workload
timezone = 'Europe/London'
PGCONF
)"
	if [ ! -f "$_pg_tuning_conf" ] || ! diff -q <(echo "$_desired_pg_tuning") "$_pg_tuning_conf" > /dev/null 2>&1; then
		echo "  Writing PostgreSQL tuning config to $_pg_tuning_conf..."
		echo "$_desired_pg_tuning" | sudo tee "$_pg_tuning_conf" > /dev/null
		if [ "$IS_DOCKER" = false ]; then
			sudo systemctl reload postgresql
		else
			sudo pg_ctlcluster 17 main reload
		fi
		echo "  PostgreSQL tuning applied and service reloaded."
	else
		echo "  PostgreSQL tuning config already present — skipping."
	fi
fi


# ##############################################################################
# SECTION 4: Configure .env.local
# ##############################################################################

echo -e "\n\033[1mConfiguring .env.local\033[0m"

touch "$REPO_ROOT/.env.local"

# APP_SECRET — set if not already set, but don't overwrite if present
if ! grep -q "^APP_SECRET=" "$REPO_ROOT/.env.local"; then
	echo "APP_SECRET=$(openssl rand -hex 32)" >> "$REPO_ROOT/.env.local"
	echo "  Generated APP_SECRET."
else
	echo "  APP_SECRET already set — skipping."
fi

# DATABASE_URL — set if not already set, but don't overwrite if present
if ! grep -q "^DATABASE_URL=" "$REPO_ROOT/.env.local"; then
	if [ "$NODATABASE_ARG" = true ]; then
		echo "DATABASE_URL=\"postgresql://db_user:db_password@db_host:5432/db_name?serverVersion=17&charset=utf8\"" >> "$REPO_ROOT/.env.local"
		echo "  Written placeholder DATABASE_URL because local PostgreSQL setup was skipped."
	elif [ "$IS_DOCKER" = true ]; then
		echo "DATABASE_URL=\"postgresql://blueline:${DB_PASS}@localhost:5432/blueline?serverVersion=17&charset=utf8\"" >> "$REPO_ROOT/.env.local"
		echo "  Written DATABASE_URL for Docker environment."
	else
		if [ -n "$DB_PASS" ]; then
			echo "DATABASE_URL=\"postgresql://blueline:${DB_PASS}@localhost:5432/blueline?serverVersion=17&charset=utf8\"" >> "$REPO_ROOT/.env.local"
			echo "  Written DATABASE_URL for VM environment."
		else
			DB_PASS="$(openssl rand -hex 16)"
			sudo -u postgres psql -c "ALTER ROLE blueline WITH PASSWORD '${DB_PASS}';"
			echo "DATABASE_URL=\"postgresql://blueline:${DB_PASS}@localhost:5432/blueline?serverVersion=17&charset=utf8\"" >> "$REPO_ROOT/.env.local"
			echo "  DATABASE_URL was missing and PostgreSQL passwords cannot be recovered; rotated password for role 'blueline' and wrote a fresh DATABASE_URL."
		fi
	fi
else
	if [ "$NODATABASE_ARG" = true ]; then
		echo "  DATABASE_URL already set — keeping existing value while local PostgreSQL setup is skipped."
	else
		echo "  DATABASE_URL already set — skipping."
	fi
fi

# APP_ENV — set if not already set, but don't overwrite if present
if ! grep -q "^APP_ENV=" "$REPO_ROOT/.env.local"; then
	echo "APP_ENV=${APP_ENV}" >> "$REPO_ROOT/.env.local"
else
	echo "  APP_ENV already set — skipping."
fi


# ##############################################################################
# SECTION 5: PHP application dependencies
# ##############################################################################

echo -e "\n\033[1mInstalling PHP dependencies\033[0m"
cd "$REPO_ROOT"
symfony composer install --optimize-autoloader --no-progress --no-interaction


# ##############################################################################
# SECTION 6: Database schema
# ##############################################################################

echo -e "\n\033[1mSetting up database schema\033[0m"
cd "$REPO_ROOT"

if [ "$NODATABASE_ARG" = true ]; then
	echo "  Skipping database schema setup (--nodatabase)."
	echo "  Reminder: run Doctrine database/schema commands yourself once DATABASE_URL points to a configured database."
else
	# In Docker the db service starts within the app container; wait until it is ready
	if [ "$IS_DOCKER" = true ]; then
		echo "  Waiting for database to become available..."
		_db_wait_attempts=0
		until pg_isready -h localhost -U blueline -d blueline > /dev/null 2>&1; do
			_db_wait_attempts=$((_db_wait_attempts + 1))
			if [ "$_db_wait_attempts" -ge 30 ]; then
				echo "ERROR: Database did not become available after 30 attempts." >&2
				exit 1
			fi
			sleep 2
		done
		echo "  Database is ready."
	fi

	# Create database if it doesn't exist, and run schema updates
	symfony console doctrine:database:create --if-not-exists
	symfony console dbal:run-sql "CREATE EXTENSION IF NOT EXISTS fuzzystrmatch" --no-interaction 2>/dev/null || true

	SCHEMA_VALIDATE_OUTPUT="$(symfony console doctrine:schema:validate 2>&1)" || true
	echo "$SCHEMA_VALIDATE_OUTPUT"

	if echo "$SCHEMA_VALIDATE_OUTPUT" | grep -q "The database schema is not in sync"; then
		echo -e "\n\033[1mDatabase schema is out of date\033[0m"
		echo -e "\n\033[1mPending SQL updates\033[0m"
		symfony console doctrine:schema:update --dump-sql
		if [ "$NONINTERACTIVE" = true ]; then
			echo "  Non-interactive: running forced schema update..."
			symfony console doctrine:schema:update --force
		else
			echo ""
			read -r -p "  Run forced schema update now? [y/N] " RUN_SCHEMA_UPDATE
			if [[ "$RUN_SCHEMA_UPDATE" =~ ^[Yy]$ ]]; then
				echo -e "\n\033[1mRunning forced schema update\033[0m"
				symfony console doctrine:schema:update --force
			else
				echo "  Skipping forced schema update."
			fi
		fi
	fi
fi


# ##############################################################################
# SECTION 7: FrankenPHP systemd service (VM only)
# ##############################################################################

if [ "$APP_ENV" = "prod" ]; then
	resolve_skip_decision NOSERVER_ARG NOSERVER_ARG_SET "Skip FrankenPHP web server setup?"
fi

if [ "$APP_ENV" = "prod" ] && [ "$NOSERVER_ARG" = false ]; then
	echo -e "\n\033[1mConfiguring FrankenPHP systemd service\033[0m"

	# FrankenPHP — download latest binary from GitHub releases if not already installed
	if ! command -v frankenphp > /dev/null 2>&1; then
		echo "  Installing FrankenPHP..."
		_frankenphp_tag="$(curl -fsSL https://api.github.com/repos/dunglas/frankenphp/releases/latest | grep '"tag_name"' | sed -E 's/.*"tag_name": *"([^"]+)".*/\1/')"
		_frankenphp_arch="$(dpkg --print-architecture)"
		case "$_frankenphp_arch" in
			amd64) _frankenphp_binary="frankenphp-linux-x86_64" ;;
			arm64) _frankenphp_binary="frankenphp-linux-aarch64" ;;
			*) echo "ERROR: Unsupported architecture: $_frankenphp_arch" >&2; exit 1 ;;
		esac
		curl -fsSL "https://github.com/dunglas/frankenphp/releases/download/${_frankenphp_tag}/${_frankenphp_binary}" -o /tmp/frankenphp
		sudo install -m 755 /tmp/frankenphp /usr/local/bin/frankenphp
		rm /tmp/frankenphp
		echo "  FrankenPHP ${_frankenphp_tag} installed."
	else
		echo "  FrankenPHP already installed: $(frankenphp version 2>/dev/null || frankenphp --version 2>/dev/null || echo 'version unknown')"
	fi

	# Always regenerate Caddyfile (absolute path substituted in; file is .gitignored)
	cat > "$REPO_ROOT/Caddyfile" << CADDYFILE
{
	frankenphp
	order php_server before file_server
}

:8000 {
	root * ${REPO_ROOT}/public
	php_server {
		worker ./public/index.php
	}
	encode zstd gzip
}
CADDYFILE
	echo "  Caddyfile written to $REPO_ROOT/Caddyfile."

	# Build desired service unit content
	_current_user="$(whoami)"
	_current_group="$(id -gn)"
	_desired_unit="[Unit]
Description=Blueline (FrankenPHP)
After=network.target postgresql.service

[Service]
Type=notify
WorkingDirectory=${REPO_ROOT}
ExecStart=/usr/local/bin/frankenphp run --config ${REPO_ROOT}/Caddyfile
User=${_current_user}
Group=${_current_group}
Restart=on-failure
RestartSec=5s

[Install]
WantedBy=multi-user.target"

	_unit_file="/etc/systemd/system/blueline.service"

	# Write unit file only if absent or content has changed
	if [ ! -f "$_unit_file" ] || ! diff -q <(echo "$_desired_unit") "$_unit_file" > /dev/null 2>&1; then
		echo "$_desired_unit" | sudo tee "$_unit_file" > /dev/null
		echo "  Written $_unit_file."
		sudo systemctl daemon-reload
	else
		echo "  systemd unit file unchanged — skipping reload."
	fi

	sudo systemctl enable --now blueline
	echo "  blueline.service enabled and started."
elif [ "$APP_ENV" = "prod" ]; then
	echo -e "\n\033[1mSkipping FrankenPHP systemd service setup (--noserver).\033[0m"
	echo "  Reminder: configure and start your production web server manually."
fi


# ##############################################################################
# SECTION 9: Cloudflared tunnel (VM only, interactive only)
# ##############################################################################

if [ "$APP_ENV" = "prod" ]; then
	resolve_skip_decision NOCLOUDFLARED_ARG NOCLOUDFLARED_ARG_SET "Skip cloudflared install and tunnel setup?"

	if [ "$NOCLOUDFLARED_ARG" = true ]; then
		echo -e "\n\033[1mSkipping cloudflared setup (--nocloudflared).\033[0m"
		echo "  Reminder: install/configure cloudflared and your public ingress/tunnel manually."
	elif grep -q "^CLOUDFLARE_TUNNEL_ID=" "$REPO_ROOT/.env.local" 2>/dev/null; then
		echo -e "\n\033[1mCloudflared tunnel already configured — skipping.\033[0m"
	else
		# Add Cloudflare repository and install cloudflared when tunnel setup is enabled.
		if [ ! -f /etc/apt/sources.list.d/cloudflared.list ]; then
			sudo mkdir -p --mode=0755 /usr/share/keyrings
			curl -fsSL https://pkg.cloudflare.com/cloudflare-main.gpg | sudo tee /usr/share/keyrings/cloudflare-main.gpg >/dev/null
			echo 'deb [signed-by=/usr/share/keyrings/cloudflare-main.gpg] https://pkg.cloudflare.com/cloudflared any main' | sudo tee /etc/apt/sources.list.d/cloudflared.list
		fi
		sudo apt-get update -q
		sudo apt-get install -y -q cloudflared
	fi

	if [ "$NOCLOUDFLARED_ARG" = false ] && [ "$NONINTERACTIVE" = true ] && ! grep -q "^CLOUDFLARE_TUNNEL_ID=" "$REPO_ROOT/.env.local" 2>/dev/null; then
		echo -e "\n\033[1mSkipping cloudflared tunnel setup (non-interactive mode).\033[0m"
		echo "  Re-run ./bin/provision interactively to complete the tunnel setup."
	elif [ "$NOCLOUDFLARED_ARG" = false ] && ! grep -q "^CLOUDFLARE_TUNNEL_ID=" "$REPO_ROOT/.env.local" 2>/dev/null; then
		echo -e "\n\033[1mSetting up Cloudflared tunnel\033[0m"
		echo "  This will open a browser to authenticate with your Cloudflare account."
		echo "  You will need an existing Cloudflare account and Zero Trust team."
		echo

		# Authenticate with Cloudflare (opens browser)
		# cloudflared tunnel login refuses to overwrite an existing cert.pem; offer explicit re-login flow.
		_cf_cert_path="$HOME/.cloudflared/cert.pem"
		if [ -s "$_cf_cert_path" ]; then
			echo "  Found existing Cloudflare certificate at $_cf_cert_path."
			read -r -p "  Re-login and replace it? [y/N] " _replace_cf_cert
			if [[ "$_replace_cf_cert" =~ ^[Yy]$ ]]; then
				_cf_cert_backup="${_cf_cert_path}.bak.$(date +%Y%m%d%H%M%S)"
				mv "$_cf_cert_path" "$_cf_cert_backup"
				echo "  Backed up existing certificate to $_cf_cert_backup."
				cloudflared tunnel login
			else
				echo "  Keeping existing certificate; skipping cloudflared tunnel login."
			fi
		else
			cloudflared tunnel login
		fi

		# Prompt for tunnel name
		read -r -p "  Tunnel name [blueline]: " _tunnel_name
		_tunnel_name="${_tunnel_name:-blueline}"

		# Create the tunnel and extract its ID
		_tunnel_output="$(cloudflared tunnel create "$_tunnel_name" 2>&1)" || {
			echo "ERROR: Failed to create cloudflared tunnel." >&2
			echo "$_tunnel_output" >&2
			exit 1
		}
		echo "$_tunnel_output"
		TUNNEL_ID="$(printf '%s\n' "$_tunnel_output" | awk '/Created tunnel .* with id / {print $NF; exit}' | tr -d '\r')"
		if [ -z "$TUNNEL_ID" ]; then
			echo "ERROR: Could not extract tunnel ID from cloudflared output." >&2
			exit 1
		fi
		echo "  Tunnel ID: $TUNNEL_ID"

		# Prompt for public hostname
		read -r -p "  Public hostname (e.g. blueline.example.com): " _public_hostname
		if [ -z "$_public_hostname" ]; then
			echo "ERROR: Public hostname is required." >&2
			exit 1
		fi

		# Route DNS
		_route_dns_output="$(cloudflared tunnel route dns "$TUNNEL_ID" "$_public_hostname" 2>&1)" || {
			_route_dns_status=$?
			echo "ERROR: Failed to route DNS for tunnel $TUNNEL_ID to $_public_hostname." >&2
			echo "$_route_dns_output" >&2
			if ! cloudflared tunnel delete "$TUNNEL_ID" > /dev/null 2>&1; then
				echo "WARNING: Failed to delete tunnel $TUNNEL_ID after DNS routing failure. Remove it manually." >&2
			else
				echo "  Deleted tunnel $TUNNEL_ID after DNS routing failure." >&2
			fi
			exit "$_route_dns_status"
		}
		echo "$_route_dns_output"

		# Write cloudflared config
		_cf_config_dir="$HOME/.cloudflared"
		mkdir -p "$_cf_config_dir"
		cat > "$_cf_config_dir/config.yml" << CFCONFIG
tunnel: ${TUNNEL_ID}
credentials-file: ${_cf_config_dir}/${TUNNEL_ID}.json
ingress:
  - hostname: ${_public_hostname}
    service: http://localhost:8000
  - service: http_status:404
CFCONFIG
		echo "  cloudflared config written to $_cf_config_dir/config.yml."

		# Install and start cloudflared as a system service
		sudo cloudflared --config "$_cf_config_dir/config.yml" service install
		sudo systemctl enable --now cloudflared
		echo "  cloudflared service installed and started."

		# Persist tunnel ID and endpoint in .env.local
		echo "CLOUDFLARE_TUNNEL_ID=${TUNNEL_ID}" >> "$REPO_ROOT/.env.local"
		echo "ENDPOINT=https://${_public_hostname}" >> "$REPO_ROOT/.env.local"
		echo "  CLOUDFLARE_TUNNEL_ID and ENDPOINT written to .env.local."
	fi
fi


# ##############################################################################
# SECTION 10: Production finalisation (VM only)
# ##############################################################################

if [ "$APP_ENV" = "prod" ]; then
	echo -e "\n\033[1mFinalising production environment\033[0m"
	cd "$REPO_ROOT"
	symfony console cache:clear --env=prod
	symfony console cache:warm --env=prod
	"$REPO_ROOT/bin/buildFrontendAssets"
	symfony composer dump-env prod
	APP_ENV=prod symfony console error:dump -f var/cache/prod/error_pages/
	echo "  Production finalisation complete."
fi


echo -e "\n\033[1mSetup complete.\033[0m"
echo -e "\n  Next steps:"
echo    "    - Import data:            ./bin/fetchAndImportData"
if [ "$APP_ENV" = "dev" ]; then
	echo    "    - Start development:      symfony serve"
fi

if [ "$APP_ENV" = "prod" ]; then
	if [ "$NODATABASE_ARG" = true ] || [ "$NOSERVER_ARG" = true ] || [ "$NOCLOUDFLARED_ARG" = true ]; then
		echo "    - Production manual checks:"
		if [ "$NODATABASE_ARG" = true ]; then
			echo "      - Ensure a PostgreSQL database is available and DATABASE_URL is correct."
		fi
		if [ "$NOSERVER_ARG" = true ]; then
			echo "      - Ensure a production web server is configured and reachable."
		fi
		if [ "$NOCLOUDFLARED_ARG" = true ]; then
			echo "      - If you want to, configure a Cloudflare tunnel for public access."
		fi
	fi
fi

echo ""
