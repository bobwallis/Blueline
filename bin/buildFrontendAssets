#!/bin/bash
set -euo pipefail

# Build frontend assets for production and sync stable root URLs.
SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ] ; do SOURCE="$(readlink "$SOURCE")"; done
d="$( cd -P "$( dirname "$SOURCE" )" && pwd )"
repo_root="$( cd "$d/.." && pwd )"
cd "$repo_root"

# Parse options and resolve APP_ENV.
ENV_LOCAL_FILE="$repo_root/.env.local"
usage() {
cat << EOF

Usage: $0 [options]
Build frontend assets and sync root public assets.

Options:
 --env=dev|prod  Set APP_ENV directly
 --env-dev       Shortcut for --env=dev
 --env-prod      Shortcut for --env=prod
 --help          Shows this message
EOF
}

ENV_ARG=""
AFTER_DOUBLE_DASH=false
for arg in "$@"; do
	if [ "$AFTER_DOUBLE_DASH" = true ]; then
		printf >&2 '%s: unexpected positional argument: %s\n' "${0##*/}" "$arg"
		usage
		exit 1
	fi

	case "$arg" in
		--)
			AFTER_DOUBLE_DASH=true
			;;
		--env=dev|--env=prod)
			ENV_ARG="${arg#--env=}"
			;;
		--env-dev)
			ENV_ARG="dev"
			;;
		--env-prod)
			ENV_ARG="prod"
			;;
		--env=*)
			printf >&2 '%s: invalid value for --env (must be dev or prod): %s\n' "${0##*/}" "${arg#--env=}"
			usage
			exit 1
			;;
		--help)
			usage
			exit 0
			;;
		--*)
			printf >&2 '%s: unknown option: %s\n' "${0##*/}" "$arg"
			usage
			exit 1
			;;
		-*)
			printf >&2 '%s: unknown option: %s\n' "${0##*/}" "$arg"
			usage
			exit 1
			;;
		*)
			printf >&2 '%s: unexpected positional argument: %s\n' "${0##*/}" "$arg"
			usage
			exit 1
			;;
	esac
done

if [ -n "$ENV_ARG" ]; then
	APP_ENV="$ENV_ARG"
else
	APP_ENV=""
	if [ -f "$ENV_LOCAL_FILE" ]; then
		APP_ENV="$(sed -nE 's/^[[:space:]]*APP_ENV[[:space:]]*=[[:space:]]*//p' "$ENV_LOCAL_FILE" | tail -n 1 | sed -E 's/[[:space:]]*$//' | sed -E 's/^"(.*)"$/\1/; s/^\x27(.*)\x27$/\1/')"
	fi
	if [ -z "$APP_ENV" ]; then
		APP_ENV="dev"
	fi
fi

DATABASE_UPDATE=""
if [ -f "$ENV_LOCAL_FILE" ]; then
	DATABASE_UPDATE="$(sed -nE 's/^[[:space:]]*DATABASE_UPDATE[[:space:]]*=[[:space:]]*//p' "$ENV_LOCAL_FILE" | tail -n 1 | sed -E 's/[[:space:]]*$//' | sed -E 's/^"(.*)"$/\1/; s/^\x27(.*)\x27$/\1/')"
fi

mkdir -p public

# Clean generated frontend outputs to avoid stale hashed imports.
rm -rf public/assets
rm -f public/manifest.json public/importmap.json
rm -f public/favicon.ico public/favicon.svg public/favicon.svg.br public/favicon.svg.gz public/favicon.svg.zst

# Ensure files that are expected at fixed root paths exist.
cp assets/images/favicon.ico public/favicon.ico
cp assets/images/favicon.svg public/favicon.svg

# Rebuild mapped assets for production.
if [ "$APP_ENV" = "prod" ]; then
	php bin/console asset-map:compile --env=prod
	php bin/console assets:compress public/favicon.svg --env=prod
	if [ -z "$DATABASE_UPDATE" ]; then
		DATABASE_UPDATE="$(date +%s)"
		echo "DATABASE_UPDATE not found in .env.local; defaulting service worker version to current UNIX timestamp ($DATABASE_UPDATE)."
	fi
	DATABASE_UPDATE_ESCAPED="$(printf '%s' "$DATABASE_UPDATE" | sed -e 's/[|&]/\\&/g')"
	sed "s|{\$DATABASE_UPDATE}|$DATABASE_UPDATE_ESCAPED|g" assets/js/service_worker.js > public/service_worker.js
else
	echo "APP_ENV=$APP_ENV: skipping precompile in non-prod so asset changes reload automatically."
	echo "To force precompile, run with --env=prod."
fi

echo "Frontend assets ready."
