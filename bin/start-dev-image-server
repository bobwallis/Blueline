#!/bin/bash
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do SOURCE="$(readlink "$SOURCE")"; done
d="$( cd -P "$( dirname "$SOURCE" )" && pwd )"
REPO_ROOT="$( cd "$d/.." && pwd )"
cd "$REPO_ROOT"

ENV_LOCAL_FILE="$REPO_ROOT/.env.local"
SERVER_PATH="$REPO_ROOT/bin/image-server.mjs"
LOG_FILE="$REPO_ROOT/var/log/image-server.log"
PID_FILE="$REPO_ROOT/var/run/image-server.pid"

get_env_value() {
	local key="$1"
	local file="$2"
	if [ ! -f "$file" ]; then
		return 0
	fi
	sed -nE "s/^[[:space:]]*${key}[[:space:]]*=[[:space:]]*//p" "$file" \
		| tail -n 1 \
		| sed -E 's/[[:space:]]*$//' \
		| sed -E 's/^"(.*)"$/\1/; s/^\x27(.*)\x27$/\1/'
}

stop_pid_gracefully() {
	local pid="$1"
	if ! ps -p "$pid" > /dev/null 2>&1; then
		return 0
	fi
	kill "$pid" > /dev/null 2>&1 || true
	for _ in 1 2 3 4 5; do
		if ! ps -p "$pid" > /dev/null 2>&1; then
			return 0
		fi
		sleep 1
	done
	kill -9 "$pid" > /dev/null 2>&1 || true
}

if ! command -v node > /dev/null 2>&1; then
	echo "Node.js is not installed; skipping dev image server auto-start."
	exit 0
fi

if [ ! -f "$SERVER_PATH" ]; then
	echo "Image server entrypoint not found at $SERVER_PATH."
	exit 0
fi

APP_ENV_VALUE="$(get_env_value APP_ENV "$ENV_LOCAL_FILE")"
if [ -z "$APP_ENV_VALUE" ]; then
	APP_ENV_VALUE="dev"
fi

if [ "$APP_ENV_VALUE" != "dev" ]; then
	echo "APP_ENV=$APP_ENV_VALUE; skipping dev image server auto-start."
	exit 0
fi

IMAGESERVER_PORT="$(get_env_value IMAGESERVER_PORT "$ENV_LOCAL_FILE")"
FRANKENPHP_PORT="$(get_env_value FRANKENPHP_PORT "$ENV_LOCAL_FILE")"
FRANKENPHP_SCHEME="$(get_env_value FRANKENPHP_SCHEME "$ENV_LOCAL_FILE")"
BROWSER_RESTART_AFTER="$(get_env_value BROWSER_RESTART_AFTER "$ENV_LOCAL_FILE")"

if [ -z "$IMAGESERVER_PORT" ]; then
	IMAGESERVER_PORT="8001"
fi
if [ -z "$FRANKENPHP_PORT" ]; then
	FRANKENPHP_PORT="8000"
fi
if [ -z "$FRANKENPHP_SCHEME" ]; then
	FRANKENPHP_SCHEME="http"
fi

mkdir -p "$REPO_ROOT/var/log" "$REPO_ROOT/var/run"

if [ -f "$PID_FILE" ]; then
	_EXISTING_PID="$(cat "$PID_FILE" 2>/dev/null || true)"
	if [ -n "$_EXISTING_PID" ] && ps -p "$_EXISTING_PID" > /dev/null 2>&1; then
		echo "Restarting existing image server process $_EXISTING_PID from PID file..."
		stop_pid_gracefully "$_EXISTING_PID"
	fi
	rm -f "$PID_FILE"
fi

_PORT_PIDS="$(lsof -iTCP:"$IMAGESERVER_PORT" -sTCP:LISTEN -t 2>/dev/null || true)"
if [ -n "$_PORT_PIDS" ]; then
	for _PID in $_PORT_PIDS; do
		_CMD="$(ps -p "$_PID" -o args= 2>/dev/null || true)"
		if echo "$_CMD" | grep -Eq 'node .*bin/image-server\.mjs'; then
			echo "Restarting existing image server process $_PID on port $IMAGESERVER_PORT..."
			stop_pid_gracefully "$_PID"
		else
			echo "Port $IMAGESERVER_PORT is in use by a non-image-server process ($_PID: $_CMD)."
			echo "Stop that process or change IMAGESERVER_PORT before starting the image server."
			exit 1
		fi
		done
fi

if [ -n "$BROWSER_RESTART_AFTER" ]; then
	IMAGE_SERVER_ENV=(
		"IMAGESERVER_PORT=$IMAGESERVER_PORT"
		"FRANKENPHP_PORT=$FRANKENPHP_PORT"
		"FRANKENPHP_SCHEME=$FRANKENPHP_SCHEME"
		"BROWSER_RESTART_AFTER=$BROWSER_RESTART_AFTER"
	)
else
	IMAGE_SERVER_ENV=(
		"IMAGESERVER_PORT=$IMAGESERVER_PORT"
		"FRANKENPHP_PORT=$FRANKENPHP_PORT"
		"FRANKENPHP_SCHEME=$FRANKENPHP_SCHEME"
	)
fi

env "${IMAGE_SERVER_ENV[@]}" nohup node "$SERVER_PATH" >> "$LOG_FILE" 2>&1 < /dev/null &
NEW_PID=$!
printf '%s\n' "$NEW_PID" > "$PID_FILE"

echo "Started development image server on http://127.0.0.1:${IMAGESERVER_PORT} (pid: $NEW_PID)."
echo "Logs: $LOG_FILE"